# 复制为 .env 并填入你的值 (.env 不会被 git 跟踪)

# NCBI E-utilities (抓取 PubMed 用; API key 免费申请: https://www.ncbi.nlm.nih.gov/account/)
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# UMLS / SNOMED 安装产物路径 (MetamorphoSys 安装完后填)
UMLS_META_DIR=data/raw/umls/2026AA/META
SNOMED_RF2_DIR=data/raw/snomed

# Neo4j (后续建图阶段)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LLM (后续问答阶段; 可选)
OPENAI_API_KEY=
